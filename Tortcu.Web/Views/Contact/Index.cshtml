@model Tortcu.Web.ViewModels.ContactViewModel

@{
    var phoneDigits = new string((Model.Phone ?? "").Where(char.IsDigit).ToArray());
    var whatsappDigits = new string((Model.Whatsapp ?? "").Where(char.IsDigit).ToArray());
}

<section class="section">
    <div class="container">

        <div class="card pad contact-header">
            <div class="pill highlight">Əlaqə</div>
            <h1>Bizimlə əlaqə saxlayın</h1>
            <p>
                Suallarınız, sifarişləriniz və ya təklifləriniz üçün bizimlə əlaqə saxlayın.
                Sizə kömək etməkdən məmnunuq.
            </p>
        </div>

        <div class="contact-layout">

            <div class="contact-methods">
                <a href="tel:@phoneDigits" class="card pad contact-item">
                    <div class="contact-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                    </div>
                    <div class="contact-info">
                        <span class="contact-label">Telefon</span>
                        <span class="contact-value">@Model.Phone</span>
                    </div>
                    <span class="contact-arrow">&rarr;</span>
                </a>

                <a href="https://wa.me/@whatsappDigits" target="_blank" rel="noopener" class="card pad contact-item contact-item--whatsapp">
                    <div class="contact-icon">
                        <img src="~/images/whatsapp.png" alt="WhatsApp" />
                    </div>
                    <div class="contact-info">
                        <span class="contact-label">WhatsApp</span>
                        <span class="contact-value">Mesaj göndərin</span>
                    </div>
                    <span class="contact-arrow">&rarr;</span>
                </a>

                <a href="https://www.instagram.com/@Model.Instagram" target="_blank" rel="noopener" class="card pad contact-item contact-item--instagram">
                    <div class="contact-icon">
                        <img src="~/images/instagram.png" alt="Instagram" />
                    </div>
                    <div class="contact-info">
                        <span class="contact-label">Instagram</span>
                        <span class="contact-value">@@@Model.Instagram</span>
                    </div>
                    <span class="contact-arrow">&rarr;</span>
                </a>

                <a href="mailto:@Model.Email" class="card pad contact-item">
                    <div class="contact-icon">
                        <img src="~/images/email.png" alt="Email" />
                    </div>
                    <div class="contact-info">
                        <span class="contact-label">Email</span>
                        <span class="contact-value">@Model.Email</span>
                    </div>
                    <span class="contact-arrow">&rarr;</span>
                </a>

                <div class="card pad contact-item contact-item--location">
                    <div class="contact-icon">
                        <img src="~/images/location.png" alt="Məkan" />
                    </div>
                    <div class="contact-info">
                        <span class="contact-label">Ünvan</span>
                        <span class="contact-value">@Model.Address</span>
                    </div>
                </div>
            </div>

            <div class="contact-map card">
                @if (!string.IsNullOrWhiteSpace(Model.MapEmbedUrl))
                {
                    <iframe
                        title="Tortcu - Xəritə"
                        src="@Model.MapEmbedUrl"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        allowfullscreen>
                    </iframe>
                }
                else
                {
                    <div class="placeholder-media" style="min-height: 100%;">
                        Xəritə yüklənir...
                    </div>
                }
            </div>

        </div>

    </div>
</section>

@section Schema {
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "LocalBusiness",
          "name": "Tortcu",
          "telephone": "@Model.Phone",
          "email": "@Model.Email",
          "address": {
            "@@type": "PostalAddress",
            "addressLocality": "Bakı",
            "addressCountry": "AZ",
            "streetAddress": "@Model.Address"
          },
          "url": "@(ViewData["CanonicalUrl"] ?? "")",
          "sameAs": [
            "https://www.instagram.com/@Model.Instagram",
            "https://wa.me/@whatsappDigits"
          ]
        }
    </script>
}
