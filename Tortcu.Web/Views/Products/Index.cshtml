@model Tortcu.Web.ViewModels.ProductsIndexViewModel

<section class="section">
    <div class="container">
        <div class="card pad">
            <h1>@(Model.CategoryName ?? "Məhsullar")</h1>
            <p style="margin: 0; color: var(--muted);">
                Filter panel (sadə) + grid layout.
            </p>
        </div>

        <div style="height: 14px;"></div>

        <div class="card pad">
            <div class="filters" aria-label="Category filters">
                <a class="chip @(string.IsNullOrWhiteSpace(Model.CategorySlug) ? "active" : "")" href="/products">Hamısı</a>
                @foreach (var c in Model.Categories)
                {
                    <a class="chip @(Model.CategorySlug == c.Slug ? "active" : "")" href="/products/@c.Slug">@c.Name</a>
                }
            </div>
        </div>

        <div style="height: 14px;"></div>

        <div class="grid">
            @if (Model.Products.Count == 0)
            {
                @for (var i = 0; i < 8; i++)
                {
                    <div class="card product">
                        <div class="thumb"><div class="noimg">Şəkil placeholder</div></div>
                        <strong>Məhsul (placeholder)</strong>
                        <small>₼ --</small>
                        <div style="margin-top:auto;">
                            <span class="pill">Əlaqə ilə sifariş</span>
                        </div>
                    </div>
                }
            }
            else
            {
                foreach (var p in Model.Products)
                {
                    <a class="card product" href="/products/@p.Slug">
                        <div class="thumb">
                            @if (!string.IsNullOrWhiteSpace(p.ThumbnailUrl))
                            {
                                <img src="@p.ThumbnailUrl" alt="@p.Name" loading="lazy" />
                            }
                            else
                            {
                                <div class="noimg">Şəkil yoxdur</div>
                            }
                        </div>
                        <strong>@p.Name</strong>
                        <small>@(p.CategoryName ?? "Kateqoriya")</small>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:auto;">
                            <span class="price">₼ @p.Price</span>
                            <span class="pill">Əlaqə ilə sifariş</span>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</section>

